# ============================================================
# Classic Cafe — إعدادات البيئة
# انسخ هذا الملف وسمّه .env.local ثم عبّي القيم الحقيقية بالأسفل
# (.env.local لا يُرفع على GitHub تلقائياً — راجع .gitignore)
# ============================================================

# رابط ومفتاح مشروع Supabase (Settings > API في لوحة تحكم Supabase)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# رمز PIN الذي يستخدمه الكاشير لفتح لوحة إضافة النقاط (4 أرقام)
VITE_CASHIER_PIN=1234
